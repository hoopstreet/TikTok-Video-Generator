{
  "name": "tiktok-video-generator",
  "version": "9.15.4",
  "description": "Automated short-form video creator for TikTok Affiliate marketing and Social Commerce. Unified Build 9.15.4.",
  "main": "dist/index.js",
  "bugs": "https://github.com/hoopstreet/TikTok-Video-Generator/issues",
  "homepage": "https://github.com/hoopstreet/TikTok-Video-Generator",
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json && vite build",
    "dev": "vite build --watch | node --watch -r ts-node/register src/index.ts ",
    "start": "node dist/index.js",
    "test": "vitest",
    "prepublishOnly": "pnpm run build && echo \"#!/usr/bin/env node\\n$(cat dist/index.js)\" > dist/index.js && chmod +x dist/index.js",
    "publish:docker": "pnpm run publish:docker:tiny",
    "publish:docker:tiny": "docker buildx build --platform linux/amd64 -t hoopstreet/tiktok-video-generator:latest-tiny -t hoopstreet/tiktok-video-generator:9.15.4 -f main-tiny.Dockerfile --push ./",
    "ui:dev": "vite",
    "ui:build": "vite build",
    "ui:preview": "vite preview"
  },
  "bin": {
    "hoopstreet-video": "dist/index.js"
  },
  "files": [
    "dist",
    "static"
  ],
  "keywords": [
    "shorts",
    "mcp",
    "tiktok-affiliate",
    "hoopstreet",
    "remotion",
    "video-automation"
  ],
  "author": "hoopstreet <hoopstreet143@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@mui/icons-material": "^5.15.10",
    "@mui/material": "^5.15.10",
    "@remotion/bundler": "^4.0.286",
    "@remotion/cli": "^4.0.286",
    "@remotion/google-fonts": "^4.0.286",
    "@remotion/install-whisper-cpp": "^4.0.286",
    "@remotion/renderer": "^4.0.286",
    "@remotion/zod-types": "^4.0.286",
    "@tanstack/react-query": "^5.18.0",
    "@types/react-dom": "^19.1.3",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.9.0",
    "content-type": "^1.0.5",
    "cuid2": "^2.2.2",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.3.0",
    "kokoro-js": "^1.2.0",
    "nock": "^14.0.3",
    "pino": "^9.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.3",
    "remotion": "^4.0.286",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "^4.0.286",
    "@types/content-type": "^1.1.8",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/fs-extra": "^11.0.4",
    "@types/nock": "^11.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.24.0",
    "postcss": "^8.4.31",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
